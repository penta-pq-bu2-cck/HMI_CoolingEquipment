<?xml version="1.0"?>
<configuration>
   
  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
    <section name="DefaultSECSLibrary" type="System.Configuration.AppSettingsSection"/>
    <section name="SECSLogger" type="System.Configuration.AppSettingsSection"/>
    <section name="GEMDatabase" type="System.Configuration.AppSettingsSection"/>
  </configSections>

  <connectionStrings>
	  <add name ="dbconnstring" connectionString="provider=microsoft.ace.oledb.16.0; data source=GEM.accdb"/>
    <!--<add name="dbconnstring" connectionString="Data Source=GEM;Version=3"/>-->
  </connectionStrings>

  <!--SQLite,AccessDB-->
  <GEMDatabase>
    <add key="DatabaseType" value="AccessDB"/>
  </GEMDatabase>
  
  <DefaultSECSLibrary>
    <add key="FilePath" value="Default.xml"/>
    <!--<add key="FilePath" value="HostScript.xml"/>-->
  </DefaultSECSLibrary>

  <SECSLogger>
    <add key="LogFileName" value="SECSPro"/>
    <add key="LogFilePath" value="Log\\"/>
    <add key="LogFileTraceLevel" value="2"/>
  </SECSLogger>
  
  <log4net>
    <appender name="LogAppender" type="log4net.Appender.RollingFileAppender">
      <file value=".\Log\GEMPro.log"/>
      <appendToFile value="true"/>
      <rollingStyle value="Size"/>
      <maxSizeRollBackups value="10"/>
      <maximumFileSize value="5MB"/>
      <staticLogFileName value="true"/>
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%-5p %d: %m%n"/>
      </layout>
    </appender>
    <logger name="GEMProLog">
      <level value="All"/>
      <appender-ref ref="LogAppender"/>
    </logger>
  </log4net>

  <startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5"/></startup>
</configuration>
