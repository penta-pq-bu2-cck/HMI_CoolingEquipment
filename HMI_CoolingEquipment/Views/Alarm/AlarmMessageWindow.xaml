        </TabItem>
        <i:Interaction.Triggers>
            <i:EventTrigger EventName="SelectionChanged">
                <i:InvokeCommandAction Command="{Binding ViewModel.AlarmStatusTabControlCommand}" CommandParameter="{Binding ElementName=AlarmStatusTabControl}" />
            </i:EventTrigger>
        </i:Interaction.Triggers>
    </TabControl>
</Window>
