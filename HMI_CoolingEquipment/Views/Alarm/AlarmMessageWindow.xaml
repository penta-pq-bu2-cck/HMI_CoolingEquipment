<Window x:Class="HMI_CoolingEquipment.Views.AlarmMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HMI_CoolingEquipment.Views" xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity" xmlns:cmd="http://www.galasoft.ch/mvvmlight"
        mc:Ignorable="d"
        Title="Alarm Message" Height="450" Width="Auto" WindowStartupLocation="CenterScreen"
        x:Name="AlarmMessageWindowView" Topmost="True">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing">
            <cmd:EventToCommand Command="{Binding ViewModel.AlarmMessageWindowClosing}"
                                EventArgsConverter="{StaticResource EventArgsConverter}"
                                PassEventArgsToCommand="True">
                <cmd:EventToCommand.EventArgsConverterParameter>
                    <Binding ElementName="AlarmMessageWindowView"/>
                </cmd:EventToCommand.EventArgsConverterParameter>
            </cmd:EventToCommand>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <TabControl x:Name="AlarmStatusTabControl">
        <TabItem Header="Current">
            <GroupBox Margin="4,4,4,4">
                <DataGrid Grid.Column="1" AutoGenerateColumns="False" ItemsSource="{Binding ViewModel.CurrentAlarmMessage}" HorizontalGridLinesBrush="Gray" GridLinesVisibility="Horizontal" CanUserAddRows="False" IsReadOnly="True" MinColumnWidth="150">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date/Time" Binding="{Binding AlarmDateTime}" FontSize="15"/>
                        <DataGridTextColumn Header="Alarm Type" Binding="{Binding AlarmType}" FontSize="15"/>
                        <DataGridTextColumn Header="Alarm Code" Binding="{Binding AlarmCode}" FontSize="15"/>
                        <DataGridTextColumn Header="Module" Binding="{Binding AlarmModule}" FontSize="15"/>
                        <DataGridTextColumn Header="Message" Binding="{Binding AlarmMessage}" FontSize="15"/>
                        <DataGridTextColumn Header="Action" Binding="{Binding AlarmAction}" FontSize="15"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
