        </TabItem>
        <TabItem Header="History">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45*"/>
                    <ColumnDefinition Width="871*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,5,0" Grid.ColumnSpan="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <GroupBox Grid.Column="0">
                            <Grid Margin="10 0 10 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="0"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="Date From: " HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                                <DatePicker x:Name="FromDateDP" Grid.Column="2" IsTodayHighlighted="False" SelectedDate="{Binding ViewModel.FromDate}" HorizontalAlignment = "Center" VerticalAlignment = "Center" FontSize="13" SelectedDateChanged="SelectedDateChanged"/>
                                <TextBlock Grid.Column="4" Text="Date To: " HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                                <DatePicker x:Name="ToDateDP" Grid.Column="5" IsTodayHighlighted="False" SelectedDate="{Binding ViewModel.ToDate}" HorizontalAlignment = "Center" VerticalAlignment = "Center" FontSize="13" SelectedDateChanged="SelectedDateChanged"/>
                                <Button Grid.Column="7" Height="40" Width="100" Command="{Binding ViewModel.FindAlarmHistoryCommand}" Visibility="Collapsed">
                                    <WrapPanel Orientation="Horizontal">
                                        <Image Source="/HMI_CoolingEquipment;component/Images/Icons/research.png" Height="25" Width="25" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Search" Style="{DynamicResource MaterialDesignButtonTextBlock}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="13"/>
                                    </WrapPanel>
                                    <Button.Style>
                                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource ButtonBaseStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=FromDateDP, Path=SelectedDate}" Value="">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ElementName=ToDateDP, Path=SelectedDate}" Value="">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ElementName=FromDateDP, Path=SelectedDate}" Value="{x:Null}">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ElementName=ToDateDP, Path=SelectedDate}" Value="{x:Null}">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Grid.Column="8" Height="40" Width="100" Command="{Binding ViewModel.ResetAlarmHistoryCommand}">
                                    <WrapPanel Orientation="Horizontal">
                                        <Image Source="/HMI_CoolingEquipment;component/Images/Icons/reload.png" Height="25" Width="25" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Reset" Style="{DynamicResource MaterialDesignButtonTextBlock}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="13"/>
                                    </WrapPanel>
                                </Button>
                            </Grid>
                        </GroupBox>
                        <GroupBox Grid.Column="1" Visibility="{Binding ViewModel.IsVisibleWarningErrorGB}">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Orientation="Horizontal" Margin="10 0 10 0" Visibility="{Binding ViewModel.IsVisibleWarning}">
                                    <TextBlock Grid.Column="1" Text="Warning " HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                                    <CheckBox Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding ViewModel.IsCheckedWarning}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="Checked">
                                                <i:InvokeCommandAction Command="{Binding ViewModel.WarningErrorCheckedCommand}"/>
                                            </i:EventTrigger>
                                            <i:EventTrigger EventName="Unchecked">
                                                <i:InvokeCommandAction Command="{Binding ViewModel.WarningErrorUncheckedCommand}"/>
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </CheckBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="10 0 10 0" Visibility="{Binding ViewModel.IsVisibleError}">
                                    <TextBlock Grid.Column="4" Text="Error " HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                                    <CheckBox Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding ViewModel.IsCheckedError}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="Checked">
                                                <i:InvokeCommandAction Command="{Binding ViewModel.WarningErrorCheckedCommand}"/>
                                            </i:EventTrigger>
                                            <i:EventTrigger EventName="Unchecked">
                                                <i:InvokeCommandAction Command="{Binding ViewModel.WarningErrorUncheckedCommand}"/>
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </CheckBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <Button Grid.Column="3" Height="40" Command="{Binding ViewModel.GenerateAlarmCSVCommand}">
                            <WrapPanel Orientation="Horizontal">
                                <Image Source="/HMI_CoolingEquipment;component/Images/Icons/export.png" Height="25" Width="25" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Text="Export To CSV" Style="{DynamicResource MaterialDesignButtonTextBlock}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="13"/>
                            </WrapPanel>
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource ButtonBaseStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=AlarmHistoryTable, Path=Items.Count}" Value="0">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>
                <GroupBox Grid.Row="1" Grid.ColumnSpan="2" Margin="4,4,4,4" Style="{StaticResource GroupBoxStyle}">
                    <DataGrid x:Name="AlarmHistoryTable" Grid.Column="1" AutoGenerateColumns="False" ItemsSource="{Binding ViewModel.HistoryAlarmMessage}" HorizontalGridLinesBrush="Gray" GridLinesVisibility="Horizontal" CanUserAddRows="False" IsReadOnly="True" MinColumnWidth="150">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date/Time" Binding="{Binding AlarmDateTime}" FontSize="15"/>
                            <DataGridTextColumn Header="Alarm Type" Binding="{Binding AlarmType}" FontSize="15"/>
                            <DataGridTextColumn Header="Alarm Code" Binding="{Binding AlarmCode}" FontSize="15"/>
                            <DataGridTextColumn Header="Module" Binding="{Binding AlarmModule}" FontSize="15"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding AlarmMessage}" FontSize="15"/>
                            <DataGridTextColumn Header="Action" Binding="{Binding AlarmAction}" FontSize="15"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
