<UserControl x:Class="HMI_CoolingEquipment.Views.SecsGem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:ie="http://schemas.microsoft.com/expression/2010/interactivity"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <GroupBox Grid.Column="0" Header="SecsGem Activity Log">
            <ScrollViewer  VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ViewModel.SecsGemLog, IsAsync=True}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Value}" FontSize="15" Margin="6 0 0 0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </GroupBox>
        <StackPanel Grid.Column="1">
            <GroupBox Header="SecsGem Status" VerticalAlignment="Top">
                <StackPanel>
                    <CheckBox Style="{StaticResource IndicatorCheckBox}" Content="{Binding ViewModel.SecsGemConnection.ConnectionStatus}" IsChecked="{Binding ViewModel.SecsGemConnection.IsConnected}" IsHitTestVisible="False">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.1" ScaleY="1.1" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                    <UniformGrid Columns="1" Visibility="{Binding ViewModel.SecsGemConnectionBtn}">
                        <Button Content="Connect" Height="40" Command="{Binding ViewModel.BtnConnectionCommand}" CommandParameter="Connect" Visibility="{Binding ViewModel.ConnectBtn}" IsEnabled="{Binding ViewModel.ConnectBtnIsEnable}"/>
                        <Button Content="Disconnect" Height="40" Command="{Binding ViewModel.BtnConnectionCommand}" CommandParameter="Disconnect" Visibility="{Binding ViewModel.DisconnectBtn}"/>
                        <Button Content="Cancel" Height="40" Command="{Binding ViewModel.BtnConnectionCommand}" CommandParameter="Cancel" Visibility="{Binding ViewModel.CancelBtn}" Background="Red"/>
                    </UniformGrid>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="SecsGem Settings" VerticalAlignment="Top">
                <Button Content="Open" Height="40" Command="{Binding ViewModel.OpenSecsGemSettingsCommand}"/>
            </GroupBox>
            <GroupBox Header="SecsGem Fire Event Tester" VerticalAlignment="Top" Visibility="Collapsed">
                <StackPanel>
                    <GroupBox Header="Variable ID">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding ViewModel.VariableID}" Margin="10 0 10 0" FontSize="15" Width="210"/>
                            <Image Source="pack://application:,,,/HMI_CoolingEquipment;component/Images/Icons/help.png" Height="30">
                                <ie:Interaction.Triggers>
                                    <ie:EventTrigger EventName="MouseLeftButtonDown">
                                        <ie:InvokeCommandAction Command="{Binding ViewModel.IconVarIDCommand}" />
                                    </ie:EventTrigger>
                                </ie:Interaction.Triggers>
                            </Image>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Variable Value">
                        <TextBox Text="{Binding ViewModel.VariableValue}" Margin="10 0 10 0" FontSize="15" />
                    </GroupBox>
                    <GroupBox Header="CEID">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding ViewModel.CEID}" Margin="10 0 10 0" FontSize="15" Width="210"/>
                            <Image Source="pack://application:,,,/HMI_CoolingEquipment;component/Images/Icons/help.png" Height="30">
                                <ie:Interaction.Triggers>
                                    <ie:EventTrigger EventName="MouseLeftButtonDown">
                                        <ie:InvokeCommandAction Command="{Binding ViewModel.IconCEIDCommand}" />
                                    </ie:EventTrigger>
                                </ie:Interaction.Triggers>
                            </Image>
                        </StackPanel>
                    </GroupBox>
                    <UniformGrid Rows="1" Columns="2">
                        <Button Content="Sent" Height="40" Command="{Binding ViewModel.BtnSentEventTesterCommand}" CommandParameter="Sent"/>
                        <Button Content="Clear" Height="40" Command="{Binding ViewModel.BtnSentEventTesterCommand}" CommandParameter="Clear" Background="Red"/>
                    </UniformGrid>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="SecsGem Fire Event Tester" VerticalAlignment="Top" Visibility="Visible">
                <UniformGrid Rows="4">
                    <Button Content="Trigger Initialize Job" Click="InitJob_Click"/>
                    <Button Content="Trigger LoadPort Ready To Load" Click="LoadPortRTL_Click"/>
                    <Button Content="Trigger LoadPort Ready To Blocked" Click="LoadPortB_Click"/>
                    <Button Content="Trigger LoadPort Ready To Unload" Click="LoadPortRTU_Click"/>
                </UniformGrid>
            </GroupBox>
        </StackPanel>
    </Grid>
</UserControl>
