<Window x:Class="HMI_CoolingEquipment.Views.UserAccountSignInView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HMI_CoolingEquipment.Views" xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity" xmlns:cmd="http://www.galasoft.ch/mvvmlight"
        mc:Ignorable="d"
        x:Name="UserAccountSignInWindow" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        TextElement.FontSize="16" TextElement.FontWeight="Regular"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="Auto"
        Title="Sign In" Topmost="True" WindowStartupLocation="CenterScreen" Height="400" Width="320">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing">
            <cmd:EventToCommand Command="{Binding ViewModel.UserAccountSignInViewClosingCommand}"
                                EventArgsConverter="{StaticResource EventArgsConverter}"
                                PassEventArgsToCommand="True">
                <cmd:EventToCommand.EventArgsConverterParameter>
                    <MultiBinding Converter="{StaticResource UserAccountSignInModelConverter}">
                        <Binding ElementName="UserAccountSignInWindow" />
                        <Binding ElementName="UserAccountSignInMessageTextBlock" />
                        <Binding ElementName="UserAccountUserNameTextBox" />
                        <Binding ElementName="SignInBtn" />
                        <Binding ElementName="UserAccountPasswordBox" />
                    </MultiBinding>
                </cmd:EventToCommand.EventArgsConverterParameter>
            </cmd:EventToCommand>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid FocusManager.FocusedElement="{Binding ElementName=UserAccountUserNameTextBox}" Margin="40 10 40 40">
        <Grid.RowDefinitions>
            <RowDefinition Height="200" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <!--<RowDefinition Height="50"/>-->
            </Grid.RowDefinitions>
            <Image Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Source="pack://application:,,,/HMI_CoolingEquipment;component/Images/Infineon.png" Height="120"/>
            <!--<Image Grid.Row="1" Grid.Column="0" Source="pack://application:,,,/HMI_CoolingEquipment;component/Images/Icons/pentamasterlogo.ico" Margin="0 -60 0 0" Width="70"/>-->
        </Grid>

        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Name="UserAccountSignInMessageTextBlock"
                   Style="{StaticResource KeyTextBlockStyle}" Foreground="Red"
                   Text="User Name or Password Incorrect" Visibility="{Binding ViewModel.WrongPasswordUsername}" />

        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource KeyTextBlockStyle}"
                   Text="User Name: " />
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="UserAccountUserNameTextBox" KeyDown="UserAccountUserNameTextBox_KeyDown" TextChanged="UsernameTextChanged"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource KeyTextBlockStyle}"
                   Text="Password: " />
        <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="UserAccountPasswordBox" KeyDown="UserAccountPasswordBox_KeyDown">
            <PasswordBox.InputBindings>
                <KeyBinding Command="{Binding UserAccountSignInCommand}" Key="Return">
                    <KeyBinding.CommandParameter>
                        <MultiBinding Converter="{StaticResource UserAccountSignInModelConverter}">
                            <Binding ElementName="UserAccountSignInWindow" />
                            <Binding ElementName="UserAccountSignInMessageTextBlock" />
                            <Binding ElementName="UserAccountUserNameTextBox" />
                            <Binding ElementName="SignInBtn" />
                            <Binding ElementName="UserAccountPasswordBox" />
                        </MultiBinding>
                    </KeyBinding.CommandParameter>
                </KeyBinding>
            </PasswordBox.InputBindings>
        </PasswordBox>

        <Button x:Name="SignInBtn" Grid.Row="4" Grid.Column="1" Command="{Binding ViewModel.UserAccountSignInCommand}"
                HorizontalAlignment="Right" Margin="0 10 0 0" >
            <Button.Style>
                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource ButtonBaseStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=UserAccountUserNameTextBox, Path=Text}"
                                     Value="">
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ElementName=UserAccountUserNameTextBox, Path=Text}"
                                     Value="{x:Null}">
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>

            <Button.CommandParameter>
                <MultiBinding Converter="{StaticResource UserAccountSignInModelConverter}">
                    <Binding ElementName="UserAccountSignInWindow" />
                    <Binding ElementName="UserAccountSignInMessageTextBlock" />
                    <Binding ElementName="UserAccountUserNameTextBox" />
                    <Binding ElementName="SignInBtn" />
                    <Binding ElementName="UserAccountPasswordBox" />
                </MultiBinding>
            </Button.CommandParameter>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Source="pack://application:,,,/HMI;component/Icons/SignIn.png" Width="40" />
                <TextBlock Grid.Column="1" Style="{StaticResource ValueTextBlockStyle}"
                           Text="Sign In" />
            </Grid>
        </Button>
    </Grid>
</Window>
