<Window x:Class="HMI_CoolingEquipment.Views.CarrierDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HMI_CoolingEquipment.Views" xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity" xmlns:cmd="http://www.galasoft.ch/mvvmlight"
        mc:Ignorable="d"
        Title="Carrier Details" Height="450" Width="Auto" x:Name="CarrierDetailsWindowView" Topmost="True">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing">
            <cmd:EventToCommand Command="{Binding ViewModel.CarrierDetailsClosingCommand}"
                                EventArgsConverter="{StaticResource EventArgsConverter}"
                                PassEventArgsToCommand="True">
                <cmd:EventToCommand.EventArgsConverterParameter>
                    <Binding ElementName="CarrierDetailsWindowView"/>
                </cmd:EventToCommand.EventArgsConverterParameter>
            </cmd:EventToCommand>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <GroupBox Margin="4,4,4,4" Visibility="{Binding ViewModel.IsJobDetailsVisible}">
            <DataGrid AutoGenerateColumns="False" x:Name="JobDetails" HorizontalGridLinesBrush="Gray" GridLinesVisibility="Horizontal" CanUserAddRows="False" IsReadOnly="True" MinColumnWidth="150" ItemsSource="{Binding ViewModel.DisplayJobDetails}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Carrier ID" Binding="{Binding CarrierID}" FontSize="15"/>
                    <DataGridTextColumn Header="Carrier Type" Binding="{Binding Type}" FontSize="15"/>
                    <DataGridTextColumn Header="LoadPort Location" Binding="{Binding PortLocation}" FontSize="15"/>
                    <DataGridTextColumn Header="Carrier Status" Binding="{Binding CarrierStatus}" FontSize="15"/>
                    <DataGridTextColumn Header="Loading Time" Binding="{Binding LoadingTime}" FontSize="15"/>
                    <DataGridTextColumn Header="Load By" Binding="{Binding LoadBy}" FontSize="15"/>
                    <DataGridTextColumn Header="Unloading Time" Binding="{Binding UnloadingTime}" FontSize="15"/>
                    <DataGridTextColumn Header="Unload By" Binding="{Binding UnloadBy}" FontSize="15"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        <GroupBox Margin="4,4,4,4" Visibility="{Binding ViewModel.IsHistoryJobDetailsVisible}">
            <DataGrid AutoGenerateColumns="False" x:Name="JobDetailsHistory" HorizontalGridLinesBrush="Gray" GridLinesVisibility="Horizontal" CanUserAddRows="False" IsReadOnly="True" MinColumnWidth="150" ItemsSource="{Binding ViewModel.DisplayJobDetailsHistory}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Carrier ID" Binding="{Binding CarrierID}" FontSize="15"/>
                    <DataGridTextColumn Header="Carrier Type" Binding="{Binding Type}" FontSize="15"/>
                    <DataGridTextColumn Header="LoadPort Location" Binding="{Binding PortLocation}" FontSize="15"/>
                    <DataGridTextColumn Header="Loading Time" Binding="{Binding LoadingTime}" FontSize="15"/>
                    <DataGridTextColumn Header="Load By" Binding="{Binding LoadBy}" FontSize="15"/>
                    <DataGridTextColumn Header="Unloading Time" Binding="{Binding UnloadingTime}" FontSize="15"/>
                    <DataGridTextColumn Header="Unload By" Binding="{Binding UnloadBy}" FontSize="15"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>
